# Copy to `.env.local` and fill in values from Supabase → Project Settings → API.
# Never commit `.env.local` or put real keys in THIS file — .env.example is tracked in git.

# Project URL (https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key (safe in browser only if RLS is correct)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — server-only. Never NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase → Authentication → URL configuration:
# Site URL: use https://5nexus.diaidia.id in production (match how users open the site; avoid http vs https mismatch).
# Redirect URLs: https://5nexus.diaidia.id/auth/callback AND http://localhost:3000/auth/callback
